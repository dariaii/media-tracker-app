@model WhatsNewViewModel
@{
    ViewData["Title"] = @Localizer["Navigation_WhatsNew"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 text-muted">@Localizer["Section_WhatsNew"]</h2>
</div>

<div class="mb-4">
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.WhatsNew)"
       class="btn @(Model.ActiveFilter == null ? "btn-primary" : "btn-outline-primary") btn-sm me-1">
        <i class="bx bx-grid-alt me-1"></i> @Localizer["WhatsNew_FilterAll"]
    </a>
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.WhatsNew)" asp-route-filter="@((int)SubscriptionType.SpotifyArtist)"
       class="btn @(Model.ActiveFilter == SubscriptionType.SpotifyArtist ? "btn-success" : "btn-outline-success") btn-sm me-1">
        <i class="bx bxl-spotify me-1"></i> @Localizer["Subscription_Artist"]
    </a>
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.WhatsNew)" asp-route-filter="@((int)SubscriptionType.SpotifyPodcasts)"
       class="btn @(Model.ActiveFilter == SubscriptionType.SpotifyPodcasts ? "btn-info" : "btn-outline-info") btn-sm me-1">
        <i class="bx bxl-spotify me-1"></i> @Localizer["Subscription_Podcast"]
    </a>
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.WhatsNew)" asp-route-filter="@((int)SubscriptionType.Youtube)"
       class="btn @(Model.ActiveFilter == SubscriptionType.Youtube ? "btn-danger" : "btn-outline-danger") btn-sm me-1">
        <i class="bx bxl-youtube me-1"></i> @Localizer["Subscription_YouTubeChannel"]
    </a>
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.WhatsNew)" asp-route-filter="@((int)SubscriptionType.ApplePodcasts)"
       class="btn @(Model.ActiveFilter == SubscriptionType.ApplePodcasts ? "btn-dark" : "btn-outline-dark") btn-sm me-1">
        <i class="bx bxl-apple me-1"></i> @Localizer["Subscription_ApplePodcast"]
    </a>
</div>

@if (!Model.Items.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bx bx-news fs-1 text-muted mb-2 d-block"></i>
            <p class="mb-0 text-muted">@Localizer["WhatsNew_NoItems"]</p>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                <div class="card h-100 d-flex flex-column">
                    <!-- TOP: Image + Title -->
                    @if (item.ImageUrl is not null)
                    {
                        <div class="position-relative">
                            <img src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" 
                                 data-src="@item.ImageUrl" 
                                 class="card-img-top lazy-image" 
                                 alt="@item.Title"
                                 referrerpolicy="no-referrer"
                                 style="height: 140px; object-fit: cover;" />
                            @if (!string.IsNullOrEmpty(item.Badge))
                            {
                                var badgeClass = item.SourceType == SubscriptionType.SpotifyArtist
                                    ? "bg-success"
                                    : "bg-dark bg-opacity-75";
                                <span class="badge @badgeClass position-absolute bottom-0 end-0 m-2">
                                    @item.Badge
                                </span>
                            }
                        </div>
                    }
                    <div class="card-body py-2 px-3">
                        <h6 class="card-title mb-0 lh-sm" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @Html.Raw(item.Title)
                        </h6>
                    </div>

                    <!-- BOTTOM: Channel, date, link -->
                    <div class="card-footer border-0 pt-0 px-3 pb-3 mt-auto">
                        @if (!string.IsNullOrEmpty(item.Subtitle))
                        {
                            <p class="text-muted small mb-1 text-truncate">@item.Subtitle</p>
                        }
                        <p class="text-muted small mb-2">
                            <i class="bx bx-calendar me-1"></i>
                            @if (DateTime.TryParse(item.ReleaseDate, out var dt))
                            {
                                @dt.ToString(dt.TimeOfDay != TimeSpan.Zero ? "dd MMM yyyy HH:mm" : "dd MMM yyyy")
                            }
                            else
                            {
                                @item.ReleaseDate
                            }
                        </p>
                        @switch (item.SourceType)
                        {
                            case SubscriptionType.SpotifyArtist:
                                <a href="@item.PlatformUrl" target="_blank" class="btn btn-success btn-sm w-100">
                                    <i class="bx bxl-spotify me-1"></i> Spotify
                                </a>
                                break;
                            case SubscriptionType.SpotifyPodcasts:
                                <a href="@item.PlatformUrl" target="_blank" class="btn btn-info btn-sm w-100">
                                    <i class="bx bxl-spotify me-1"></i> Spotify
                                </a>
                                break;
                            case SubscriptionType.Youtube:
                                <a href="@item.PlatformUrl" target="_blank" class="btn btn-danger btn-sm w-100">
                                    <i class="bx bxl-youtube me-1"></i> YouTube
                                </a>
                                break;
                            case SubscriptionType.ApplePodcasts:
                                <a href="@item.PlatformUrl" target="_blank" class="btn btn-dark btn-sm w-100">
                                    <i class="bx bxl-apple me-1"></i> Apple Podcasts
                                </a>
                                break;
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
@model List<YouTubeVideo>
@{
    ViewData["Title"] = @Localizer["Navigation_Subscriptions"];
    var name = ViewBag.SubscriptionName as string;
    var image = ViewBag.SubscriptionImage as string;
    var description = ViewBag.SubscriptionDescription as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 text-muted">@Localizer["Subscription_YouTubeVideos"]</h2>
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.Index)" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-back me-1"></i> @Localizer["Subscription_BackToList"]
    </a>
</div>

@if (!string.IsNullOrEmpty(name))
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center">
                @if (!string.IsNullOrEmpty(image))
                {
                    <img src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="
                         data-src="@image"
                         alt="@name"
                         class="rounded me-3 lazy-image"
                         style="width: 110px; height: 110px; object-fit: cover;" />
                }
                <div>
                    <h3 class="mb-1">@name</h3>
                    @if (!string.IsNullOrEmpty(description))
                    {
                        <p class="text-muted mb-0" style="max-width: 600px;">
                            @(description.Length > 200 ? description[..200] + "..." : description)
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bx bxl-youtube fs-1 text-muted mb-2 d-block"></i>
            <p class="mb-0 text-muted">@Localizer["Subscription_NoVideos"]</p>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4">
        @foreach (var video in Model)
        {
            <div class="col">
                <div class="card h-100 d-flex flex-column">
                    @if (video.ImageUrl is not null)
                    {
                        <div class="position-relative">
                            <img src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="
                                 data-src="@video.ImageUrl"
                                 class="card-img-top lazy-image"
                                 alt="@video.Title"
                                 style="aspect-ratio: 16 / 9; object-fit: cover; width: 100%;" />
                            @if (!string.IsNullOrEmpty(video.Duration))
                            {
                                <span class="badge bg-dark bg-opacity-75 position-absolute bottom-0 end-0 m-2">
                                    @video.Duration
                                </span>
                            }
                        </div>
                    }
                    <div class="card-body py-2 px-3">
                        <h6 class="card-title mb-0 lh-sm" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @Html.Raw(video.Title)
                        </h6>
                    </div>
                    <div class="card-footer border-0 pt-0 px-3 pb-3 mt-auto">
                        <p class="text-muted small mb-1 text-truncate">@video.ChannelTitle</p>
                        <p class="text-muted small mb-2">
                            <i class="bx bx-calendar me-1"></i>
                            @(DateTime.TryParse(video.PublishedAt, out var dt) ? dt.ToString("dd MMM yyyy HH:mm") : video.PublishedAt)
                        </p>
                        <a href="@video.YouTubeUrl" target="_blank" class="btn btn-danger btn-sm w-100">
                            <i class="bx bxl-youtube me-1"></i> @Localizer["Subscription_WatchOnYouTube"]
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
@model string
@{
    ViewData["Title"] = @Localizer["Account_NotAuthorized"];
    Layout = "_LayoutAnonymous";
}

<p>@Localizer["Account_UserDeactivatedMessage", Model]</p>

<div class="text-center">
    <a asp-controller="Account" asp-action="@nameof(AccountController.Login)" asp-route-returnUrl="@Model"
       class="d-flex align-items-center justify-content-center">
        <i class="bx bx-chevron-left scaleX-n1-rtl bx-sm"></i>
        @Localizer["Account_BackToLogin"]
    </a>
</div>
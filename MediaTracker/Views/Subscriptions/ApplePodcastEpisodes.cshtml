@model List<ApplePodcastEpisode>
@{
    ViewData["Title"] = @Localizer["Navigation_Subscriptions"];
    var name = ViewBag.SubscriptionName as string;
    var image = ViewBag.SubscriptionImage as string;
    var description = ViewBag.SubscriptionDescription as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 text-muted">@Localizer["Subscription_PodcastEpisodes"]</h2>
    <a asp-controller="Subscriptions" asp-action="@nameof(SubscriptionsController.Index)" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-back me-1"></i> @Localizer["Subscription_BackToList"]
    </a>
</div>

@if (!string.IsNullOrEmpty(name))
{
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center">
                @if (!string.IsNullOrEmpty(image))
                {
                    <img src="@image" alt="@name" class="rounded me-3" style="width: 110px; height: 110px; object-fit: cover;" />
                }
                <div>
                    <h3 class="mb-1">@name</h3>
                    @if (!string.IsNullOrEmpty(description))
                    {
                        <p class="text-muted mb-0">@description</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bx bx-podcast fs-1 text-muted mb-2 d-block"></i>
            <p class="mb-0 text-muted">@Localizer["Subscription_NoEpisodes"]</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            @foreach (var episode in Model)
            {
                <div class="d-flex align-items-start p-3 border-bottom">
                    @if (episode.ImageUrl is not null)
                    {
                        <img src="@episode.ImageUrl" alt="@episode.Name" class="rounded me-3"
                             style="width: 110px; height: 110px; object-fit: cover; flex-shrink: 0;" />
                    }
                    <div class="flex-grow-1">
                        <h6 class="mb-1">@episode.Name</h6>
                        <p class="text-muted small mb-1">
                            <i class="bx bx-calendar me-1"></i>
                            @(DateTime.TryParse(episode.ReleaseDate, out var dt) ? dt.ToString("dd MMM yyyy") : episode.ReleaseDate)
                            <span class="mx-1">·</span>
                            <i class="bx bx-time me-1"></i>
                            @(episode.Duration.TotalHours >= 1 ? episode.Duration.ToString(@"h\:mm\:ss") : episode.Duration.ToString(@"m\:ss"))
                        </p>
                        <p class="mb-0 small text-truncate" style="max-width: 600px;">@episode.Description</p>
                    </div>
                    <div class="ms-3 align-self-center flex-shrink-0">
                        <a href="@episode.EpisodeUrl" target="_blank" class="btn btn-dark btn-sm">
                            <i class="bx bxl-apple"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
}
@model LoginViewModel
@{
    ViewData["Title"] = Localizer["Account_Login"];
    Layout = "_LayoutAnonymous";
}

<h4 class="mb-2">@Localizer["Account_WelcomeMessage"]</h4>
<p class="mb-4">@Localizer["Account_SignInPrompt"]</p>

<form id="formAuthentication" class="mb-3" asp-action="@nameof(AccountController.Login)" asp-route-returnUrl="@Model.ReturnUrl" method="POST">
    <div class="mb-3">
        <label asp-for="@Model.UserName" class="form-label">@Localizer["Account_UserName"]</label>
        <input class="form-control" type="text" asp-for="@Model.UserName" autofocus>
        <span asp-validation-for="@Model.UserName" class="text-danger"></span>
    </div>
    <div class="mb-3 form-password-toggle">
        <div class="d-flex justify-content-between">
            <label class="form-label" asp-for="@Model.Password">@Localizer["Account_Password"]</label>
            <a asp-action="@nameof(AccountController.ForgotPassword)" asp-route-returnUrl="@Model.ReturnUrl">
                <small>@Localizer["Account_ForgotPassword"]</small>
            </a>
        </div>
        <div class="input-group input-group-merge">
            <input class="form-control" type="password" asp-for="@Model.Password" aria-describedby="password" />
            <span class="input-group-text cursor-pointer"><i class="bx bx-hide"></i></span>
        </div>
        <span asp-validation-for="@Model.Password" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" asp-for="@Model.RememberMe" />
            <label class="form-check-label" asp-for="@Model.RememberMe">@Localizer["Account_RememberMe"]</label>
        </div>
    </div>
    <div class="mb-3">
        <button class="btn btn-primary d-grid w-100" type="submit">@Localizer["Account_Login"]</button>
    </div>
</form>

<p class="text-center">
    <span>@Localizer["Account_NoProfile"]</span>
    <a asp-controller="Account" asp-action="@nameof(AccountController.Register)" asp-route-returnUrl="@Model.ReturnUrl">
        <span>@Localizer["Account_RegisterHere"]</span>
    </a>
</p>